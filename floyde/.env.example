# ── Floyde environment ────────────────────────────────────────────────
# Copy to .env and fill in. Nothing here is required to boot in dev:
# sensible defaults let the API + MCP server run against SQLite with
# external integrations stubbed.

# App
FLOYDE_ENV=development
FLOYDE_SECRET_KEY=change-me-in-production-please-32+chars
FLOYDE_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database — leave unset to use local SQLite (floyde.db).
# For Docker/Postgres the compose file sets this for you.
# FLOYDE_DATABASE_URL=postgresql+psycopg://floyde:floyde@db:5432/floyde

# Stripe — if unset, payments run in STUB mode (fake intents, no network).
# FLOYDE_STRIPE_SECRET_KEY=sk_test_...
# FLOYDE_STRIPE_WEBHOOK_SECRET=whsec_...

# Amazon Product Advertising API — if unset, recs come from a curated
# offline catalog so the feature works without credentials.
# FLOYDE_AMAZON_ACCESS_KEY=
# FLOYDE_AMAZON_SECRET_KEY=
# FLOYDE_AMAZON_PARTNER_TAG=floyde-20
# FLOYDE_AMAZON_REGION=us-east-1

# Bookkeeping sync — "none" | "frappe" | "akaunting"
FLOYDE_BOOKKEEPING_PROVIDER=none
# FLOYDE_BOOKKEEPING_BASE_URL=
# FLOYDE_BOOKKEEPING_API_KEY=

# Concierge (Ruby) — premium live-voice. Stubbed until wired.
# FLOYDE_CONCIERGE_WEBHOOK_URL=
